+    return path;
+  }
+
+  char cwd[FN_REFLEN];
+  if (getcwd(cwd, sizeof(cwd)) == nullptr) {
+    return path;
+  }
+
+  int written = snprintf(buffer, buffer_len, "%s/%s", cwd, path);
+  if (written < 0 || static_cast<size_t>(written) >= buffer_len) {
+    errno = ENAMETOOLONG;
+    return nullptr;
+  }
+
+  return buffer;
